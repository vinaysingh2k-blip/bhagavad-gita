# ==============================================================================
# Environment Variables — copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ==============================================================================

# --- Razorpay (get these from https://dashboard.razorpay.com/app/keys) -------
# Use the account for: synapsedigitalsolutions.dm@gmail.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret configured in Razorpay Dashboard > Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Backend server -----------------------------------------------------------
PORT=4000

# --- Frontend (optional, if you wire index.html to read this at build time) --
# For a pure static deploy, instead just edit CONFIG in script.js directly:
#   CONFIG.RAZORPAY_PAYMENT_LINK  -> your real Razorpay Payment Link, OR
#   CONFIG.RAZORPAY_KEY_ID        -> your real public Key ID (safe to expose)
#   CONFIG.USE_INLINE_CHECKOUT    -> true, if using the advanced flow
