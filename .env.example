# ==============================================================================
# Environment Variables — copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to version control.
# ==============================================================================

# --- Razorpay (get these from https://dashboard.razorpay.com/app/keys) -------
# Use the account for: synapsedigitalsolutions.dm@gmail.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Webhook secret configured in Razorpay Dashboard > Settings > Webhooks
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Backend server -----------------------------------------------------------
# One backend instance serves all 4 landing pages (amount/product are passed
# dynamically per-page), so only one set of values is needed here.
PORT=4000

# --- Frontend (optional, if you wire pages to read this at build time) -------
# For a pure static deploy, instead edit each landing-page-N/config.js directly:
#   PAGE_CONFIG.RAZORPAY_PAYMENT_LINK  -> your real Razorpay Payment Link, OR
#   PAGE_CONFIG.RAZORPAY_KEY_ID        -> your real public Key ID (safe to expose)
#   PAGE_CONFIG.USE_INLINE_CHECKOUT    -> true, if using the advanced flow
# Repeat for landing-page-1, -2, -3, and -4 (same values work across all four).
